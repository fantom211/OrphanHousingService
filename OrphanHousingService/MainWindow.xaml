<Window x:Class="OrphanHousingService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OrphanHousingService"
        mc:Ignorable="d"
        Title="Жилищный фонд — учёт"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource CanvasBrush}"
        FontFamily="Segoe UI"
        Height="1080"
        Width="1920">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                Padding="16,20">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="4,0,4,24">
                    
                    <Border Background="#1F2937"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="ЖИЛИЩНЫЙ ФОНД"
                                       Foreground="White"
                                       FontSize="13"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Система учёта"
                                       Foreground="#9CA3AF"
                                       FontSize="12"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel>
                    
                    <TextBlock Text="РАЗДЕЛЫ"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="12,0,0,8"/>

                    <Button Content="Договоры"
                            Command="{Binding OpenContractsCommand}"
                            Style="{StaticResource SidebarButton}"/>
                    <Button Content="Квартиры"
                            Command="{Binding OpenApartmentsCommand}"
                            Style="{StaticResource SidebarButton}"/>
                    <Button Content="Люди"
                            Command="{Binding OpenPeopleCommand}"
                            Style="{StaticResource SidebarButton}"/>
                    <Button Content="История квартир"
                            Command="{Binding OpenApartmentStatusHistoryCommand}"
                            Style="{StaticResource SidebarButton}"/>
                    <Button Content="Заявления"
                            Command="{Binding OpenApplicationsCommand}"
                            Style="{StaticResource SidebarButton}"/>
                    <Button Content="Решения комиссии"
                            Command="{Binding OpenCommissionDecisionsCommand}"
                            Style="{StaticResource SidebarButton}"/>
                    <Button Content="Долги ЖКХ"
                            Command="{Binding OpenUtilityDebtsCommand}"
                            Style="{StaticResource SidebarButton}"/>
                    <Button Content="Состав семьи"
                            Command="{Binding OpenFamilyMembersCommand}"
                            Style="{StaticResource SidebarButton}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1" Margin="20,20,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0"
                    Style="{StaticResource CardBorder}"
                    Margin="0,0,0,14"
                    Padding="16,14">
                <StackPanel>
                    <TextBlock Text="Управление данными"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Добавить"
                                Command="{Binding CurrentViewModel.AddCommand}"
                                Style="{StaticResource ToolbarButton}"/>
                        <Button Content="Редактировать"
                                Command="{Binding CurrentViewModel.EditCommand}"
                                Style="{StaticResource ToolbarButton}"/>
                        <Button Content="Удалить"
                                Command="{Binding CurrentViewModel.DeleteCommand}"
                                Style="{StaticResource DangerButton}"
                                Padding="14,8"
                                Margin="0,0,8,0"
                                MinHeight="34"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Content -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="12">
                <ContentControl Content="{Binding CurrentViewModel}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"/>
            </Border>
        </Grid>
    </Grid>
</Window>
