<UserControl x:Class="OrphanHousingService.Views.CommissionDecisionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:OrphanHousingService.Views.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SearchPanel Grid.Row="0"/>

        <DataGrid Grid.Row="1"
                  Style="{StaticResource ModernDataGrid}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  ItemsSource="{Binding CommissionDecisions}"
                  SelectedItem="{Binding SelectedCommissionDecision}">

            <DataGrid.InputBindings>
                <MouseBinding Gesture="LeftDoubleClick"
                              Command="{Binding OpenDetailsCommand}" />
            </DataGrid.InputBindings>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер заявки" Binding="{Binding Application.ApplicationNumber}" />
                <DataGridTextColumn Header="Тип решения" Binding="{Binding DisplayDecisionType}" />
                <DataGridTextColumn Header="Номер решения" Binding="{Binding DecisionNumber}" />
                <DataGridTextColumn Header="Дата решения" Binding="{Binding DecisionDate, StringFormat=dd.MM.yyyy}" />
                <DataGridTextColumn Header="Результат" Binding="{Binding DisplayResult}" />
                <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" />
                <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" />
                <DataGridTextColumn Header="Добавлено" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
