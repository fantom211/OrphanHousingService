<Window x:Class="OrphanHousingService.Views.Details.ApartmentDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Квартира"
        Height="580"
        Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Сведения о квартире" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Адрес:" Grid.Row="0" Grid.Column="0" Margin="0,4"/>
            <TextBlock Text="{Binding Apartment.Address}" Grid.Row="0" Grid.Column="1" Margin="0,4"/>
            <TextBlock Text="Статус:" Grid.Row="0" Grid.Column="2" Margin="0,4"/>
            <TextBlock Text="{Binding Apartment.StatusDisplay}" Grid.Row="0" Grid.Column="3" Margin="0,4"/>

            <TextBlock Text="Площадь:" Grid.Row="1" Grid.Column="0" Margin="0,4"/>
            <TextBlock Text="{Binding Apartment.Area}" Grid.Row="1" Grid.Column="1" Margin="0,4"/>
            <TextBlock Text="Комнат:" Grid.Row="1" Grid.Column="2" Margin="0,4"/>
            <TextBlock Text="{Binding Apartment.RoomsCount}" Grid.Row="1" Grid.Column="3" Margin="0,4"/>

            <TextBlock Text="Кадастровый №:" Grid.Row="2" Grid.Column="0" Margin="0,4"/>
            <TextBlock Text="{Binding Apartment.CadastralNumber}" Grid.Row="2" Grid.Column="1" Margin="0,4"/>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,15,0,0">
            <TextBlock Text="История статусов" DockPanel.Dock="Top" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <DataGrid Style="{StaticResource ModernDataGrid}"
                      ItemsSource="{Binding History}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата" Binding="{Binding ChangeDate, StringFormat=dd.MM.yyyy HH:mm}" />
                    <DataGridTextColumn Header="Статус" Binding="{Binding DisplayStatus}" />
                    <DataGridTextColumn Header="Основание" Binding="{Binding Basis}" />
                    <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</Window>
