<Window x:Class="OrphanHousingService.Views.Details.ApartmentDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Квартира"
        Height="580"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Сведения о квартире" Style="{StaticResource DetailWindowTitle}"/>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Адрес:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Apartment.Address}" Style="{StaticResource DetailValueText}"/>
                    <TextBlock Grid.Column="2" Text="Статус:" Style="{StaticResource DetailLabelText}" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="3" Text="{Binding Apartment.StatusDisplay}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Площадь:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Apartment.Area}" Style="{StaticResource DetailValueText}"/>
                    <TextBlock Grid.Column="2" Text="Комнат:" Style="{StaticResource DetailLabelText}" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="3" Text="{Binding Apartment.RoomsCount}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Кадастровый №:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Apartment.CadastralNumber}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}" Margin="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Дата включения:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Apartment.IncludedToFundDate, StringFormat=dd.MM.yyyy}" Style="{StaticResource DetailValueText}"/>
                    <TextBlock Grid.Column="2" Text="Приказ №:" Style="{StaticResource DetailLabelText}" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="3" Text="{Binding Apartment.InclussionOrderNumber}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>
        </StackPanel>

        <DockPanel Grid.Row="1" Margin="0,10,0,0">
            <TextBlock Text="История статусов" DockPanel.Dock="Top" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <DataGrid Style="{StaticResource ModernDataGrid}"
                      ItemsSource="{Binding History}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата" Binding="{Binding ChangeDate, StringFormat=dd.MM.yyyy HH:mm}" />
                    <DataGridTextColumn Header="Статус" Binding="{Binding DisplayStatus}" />
                    <DataGridTextColumn Header="Основание" Binding="{Binding Basis}" />
                    <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</Window>
