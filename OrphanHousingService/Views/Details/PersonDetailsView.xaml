<Window x:Class="OrphanHousingService.Views.Details.PersonDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OrphanHousingService.Views.Details"
        mc:Ignorable="d"
        Title="PersonDetailsView" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Фамилия:" Grid.Row="0" Grid.Column="0" Margin="0,5"/>
        <TextBlock Text="{Binding Person.SurName}" Grid.Row="0" Grid.Column="1" Margin="0,5"/>

        <TextBlock Text="Имя:" Grid.Row="1" Grid.Column="0" Margin="0,5"/>
        <TextBlock Text="{Binding Person.FirstName}" Grid.Row="1" Grid.Column="1" Margin="0,5"/>

        <TextBlock Text="Отчество:" Grid.Row="2" Grid.Column="0" Margin="0,5"/>
        <TextBlock Text="{Binding Person.LastName}" Grid.Row="2" Grid.Column="1" Margin="0,5"/>

        <TextBlock Text="Дата рождения:" Grid.Row="3" Grid.Column="0" Margin="0,5"/>
        <TextBlock Text="{Binding Person.BirthDate, StringFormat=dd.MM.yyyy}" Grid.Row="3" Grid.Column="1" Margin="0,5"/>

        <TextBlock Text="Паспорт:" Grid.Row="4" Grid.Column="0" Margin="0,5"/>
        <TextBlock Text="{Binding Person.PassportData}" Grid.Row="4" Grid.Column="1" Margin="0,5"/>

        <TextBlock Text="Телефон:" Grid.Row="5" Grid.Column="0" Margin="0,5"/>
        <TextBlock Text="{Binding Person.Phone}" Grid.Row="5" Grid.Column="1" Margin="0,5"/>

        <TextBlock Text="Статус:" Grid.Row="6" Grid.Column="0" Margin="0,5"/>
        <TextBlock Text="{Binding Person.Status}" Grid.Row="6" Grid.Column="1" Margin="0,5"/>

        <GroupBox Grid.Row="7" Header="Состав семьи" Margin="0,20,0,0">
            <DataGrid ItemsSource="{Binding FamilyMembers}"
              AutoGenerateColumns="False"
              IsReadOnly="True">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ФИО"
                                Binding="{Binding FullName}" />

                    <DataGridTextColumn Header="Родство"
                                Binding="{Binding Relation}" />

                    <DataGridTextColumn Header="Дата рождения"
                                Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}" />

                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

    </Grid>
</Window>
