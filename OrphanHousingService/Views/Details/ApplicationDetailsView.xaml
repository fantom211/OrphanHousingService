<Window x:Class="OrphanHousingService.Views.Details.ApplicationDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Заявление"
        Height="400"
        Width="700"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Номер заявки:" Grid.Row="0" Grid.Column="0" Margin="0,5"/>
        <TextBlock Text="{Binding Application.ApplicationNumber}" Grid.Row="0" Grid.Column="1" Margin="0,5"/>

        <TextBlock Text="Договор:" Grid.Row="1" Grid.Column="0" Margin="0,5"/>
        <TextBlock Text="{Binding Application.Contract.ContractNumber}" Grid.Row="1" Grid.Column="1" Margin="0,5"/>

        <TextBlock Text="Тип заявки:" Grid.Row="2" Grid.Column="0" Margin="0,5"/>
        <TextBlock Text="{Binding Application.DisplayApplicationType}" Grid.Row="2" Grid.Column="1" Margin="0,5"/>

        <TextBlock Text="Дата заявки:" Grid.Row="3" Grid.Column="0" Margin="0,5"/>
        <TextBlock Text="{Binding Application.ApplicationDate, StringFormat=dd.MM.yyyy}" Grid.Row="3" Grid.Column="1" Margin="0,5"/>

        <TextBlock Text="Статус:" Grid.Row="4" Grid.Column="0" Margin="0,5"/>
        <TextBlock Text="{Binding Application.DisplayApplicationStatus}" Grid.Row="4" Grid.Column="1" Margin="0,5"/>

        <TextBlock Text="Комментарий:" Grid.Row="5" Grid.Column="0" Margin="0,5"/>
        <TextBlock Text="{Binding Application.Comment}" Grid.Row="5" Grid.Column="1" Margin="0,5" TextWrapping="Wrap"/>

        <TextBlock Text="Идентификатор:" Grid.Row="6" Grid.Column="0" Margin="0,5"/>
        <TextBlock Text="{Binding Application.Id}" Grid.Row="6" Grid.Column="1" Margin="0,5"/>

        <TextBlock Text="Договор (Id):" Grid.Row="7" Grid.Column="0" Margin="0,5"/>
        <TextBlock Text="{Binding Application.ContractId}" Grid.Row="7" Grid.Column="1" Margin="0,5"/>
    </Grid>
</Window>
