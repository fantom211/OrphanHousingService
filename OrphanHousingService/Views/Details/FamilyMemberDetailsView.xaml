<Window x:Class="OrphanHousingService.Views.Details.FamilyMemberDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Член семьи"
        Height="400"
        Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20">
        <StackPanel>
            <TextBlock Text="Сведения о члене семьи" Style="{StaticResource DetailWindowTitle}"/>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Договор:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding FamilyMember.Contract.ContractNumber}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Гражданин:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding FamilyMember.Contract.Person.FullName}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="ФИО:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding FamilyMember.FullName}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Дата рождения:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding FamilyMember.BirthDate, StringFormat=dd.MM.yyyy}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}" Margin="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Родство:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding FamilyMember.DisplayRelationshipType}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
