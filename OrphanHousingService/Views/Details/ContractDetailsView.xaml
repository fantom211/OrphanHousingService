<Window x:Class="OrphanHousingService.Views.Details.ContractDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Договор"
        Height="620"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Сведения о договоре" Style="{StaticResource DetailWindowTitle}"/>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Номер:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Contract.ContractNumber}" Style="{StaticResource DetailValueText}"/>
                    <TextBlock Grid.Column="2" Text="Статус:" Style="{StaticResource DetailLabelText}" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="3" Text="{Binding Contract.DisplayStatus}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Тип:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Contract.DisplayContractType}" Style="{StaticResource DetailValueText}"/>
                    <TextBlock Grid.Column="2" Text="Долг:" Style="{StaticResource DetailLabelText}" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="3" Text="{Binding Contract.TotalDebt}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Гражданин:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Contract.Person.FullName}" Style="{StaticResource DetailValueText}"/>
                    <TextBlock Grid.Column="2" Text="Квартира:" Style="{StaticResource DetailLabelText}" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="3" Text="{Binding Contract.Apartment.Address}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}" Margin="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Период:" Style="{StaticResource DetailLabelText}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="{Binding Contract.StartDate, StringFormat=dd.MM.yyyy}" Style="{StaticResource DetailValueText}"/>
                        <TextBlock Text=" — " Style="{StaticResource DetailValueText}"/>
                        <TextBlock Text="{Binding Contract.EndDate, StringFormat=dd.MM.yyyy}" Style="{StaticResource DetailValueText}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <DockPanel Grid.Row="1" Margin="0,10,0,0">
            <TextBlock Text="История изменений" DockPanel.Dock="Top" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <DataGrid Style="{StaticResource ModernDataGrid}"
                      ItemsSource="{Binding History}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата" Binding="{Binding ChangeDate, StringFormat=dd.MM.yyyy HH:mm}" />
                    <DataGridTextColumn Header="Операция" Binding="{Binding OperationType}" />
                    <DataGridTextColumn Header="Было" Binding="{Binding DisplayOldStatus}" />
                    <DataGridTextColumn Header="Стало" Binding="{Binding DisplayNewStatus}" />
                    <DataGridTextColumn Header="Основание" Binding="{Binding Basis}" />
                    <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</Window>
