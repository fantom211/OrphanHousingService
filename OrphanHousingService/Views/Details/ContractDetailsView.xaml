<Window x:Class="OrphanHousingService.Views.Details.ContractDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Договор"
        Height="620"
        Width="900"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Сведения о договоре" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Номер:" Grid.Row="0" Grid.Column="0" Margin="0,4"/>
            <TextBlock Text="{Binding Contract.ContractNumber}" Grid.Row="0" Grid.Column="1" Margin="0,4"/>
            <TextBlock Text="Статус:" Grid.Row="0" Grid.Column="2" Margin="0,4"/>
            <TextBlock Text="{Binding Contract.DisplayStatus}" Grid.Row="0" Grid.Column="3" Margin="0,4"/>

            <TextBlock Text="Гражданин:" Grid.Row="1" Grid.Column="0" Margin="0,4"/>
            <TextBlock Text="{Binding Contract.Person.FullName}" Grid.Row="1" Grid.Column="1" Margin="0,4"/>
            <TextBlock Text="Квартира:" Grid.Row="1" Grid.Column="2" Margin="0,4"/>
            <TextBlock Text="{Binding Contract.Apartment.Address}" Grid.Row="1" Grid.Column="3" Margin="0,4"/>

            <TextBlock Text="Период:" Grid.Row="2" Grid.Column="0" Margin="0,4"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,4">
                <Run Text="{Binding Contract.StartDate, StringFormat=dd.MM.yyyy}"/>
                <Run Text=" — "/>
                <Run Text="{Binding Contract.EndDate, StringFormat=dd.MM.yyyy}"/>
            </TextBlock>
            <TextBlock Text="Долг:" Grid.Row="2" Grid.Column="2" Margin="0,4"/>
            <TextBlock Text="{Binding Contract.TotalDebt}" Grid.Row="2" Grid.Column="3" Margin="0,4"/>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,15,0,0">
            <TextBlock Text="История изменений" DockPanel.Dock="Top" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <DataGrid Style="{StaticResource ModernDataGrid}"
                      ItemsSource="{Binding History}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата" Binding="{Binding ChangeDate, StringFormat=dd.MM.yyyy HH:mm}" />
                    <DataGridTextColumn Header="Операция" Binding="{Binding OperationType}" />
                    <DataGridTextColumn Header="Было" Binding="{Binding DisplayOldStatus}" />
                    <DataGridTextColumn Header="Стало" Binding="{Binding DisplayNewStatus}" />
                    <DataGridTextColumn Header="Основание" Binding="{Binding Basis}" />
                    <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</Window>
