<Window x:Class="OrphanHousingService.Views.Details.UtilityDebtDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Долг за коммунальные услуги"
        Height="520"
        Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource DialogWindow}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20">
        <StackPanel>
            <TextBlock Text="Сведения о долге" Style="{StaticResource DetailWindowTitle}"/>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Договор:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding UtilityDebt.Contract.ContractNumber}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Гражданин:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding UtilityDebt.Contract.Person.FullName}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Сумма:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding UtilityDebt.Amount}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Дата задолженности:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding UtilityDebt.DebtDate, StringFormat=dd.MM.yyyy}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Период с:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding UtilityDebt.PeriodStart, StringFormat=dd.MM.yyyy}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Период по:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding UtilityDebt.PeriodEnd, StringFormat=dd.MM.yyyy}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Причина:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding UtilityDebt.Reason}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Статус:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding UtilityDebt.DisplayStatus}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}" Margin="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Дата оплаты:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding UtilityDebt.PaidDate, StringFormat=dd.MM.yyyy}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
