<UserControl x:Class="OrphanHousingService.Views.ApplicationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <DataGrid Style="{StaticResource ModernDataGrid}"
            IsReadOnly="True"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding Applications}"
                  SelectedItem="{Binding SelectedApplication}"
                  GridLinesVisibility="None"
                    HeadersVisibility="Column">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Номер заявки"
                                    Binding="{Binding ApplicationNumber}"/>
                <DataGridTextColumn Header="Договор"
                                    Binding="{Binding Contract.ContractNumber}"/>

                <DataGridTextColumn Header="Тип заявки"
                                    Binding="{Binding DisplayApplicationType}"/>

                <DataGridTextColumn Header="Дата заявки"
                                    Binding="{Binding ApplicationDate}"/>

                <DataGridTextColumn Header="Статус"
                                    Binding="{Binding DisplayApplicationStatus}"/>

                <DataGridTextColumn Header="Комментарий"
                                    Binding="{Binding Comment}"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</UserControl>