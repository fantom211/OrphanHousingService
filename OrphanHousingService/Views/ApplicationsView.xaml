<UserControl x:Class="OrphanHousingService.Views.ApplicationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:OrphanHousingService.Views.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SearchPanel Grid.Row="0"/>

        <DataGrid x:Name="ApplicationsDataGrid"
                  Grid.Row="1"
                  Style="{StaticResource ModernDataGrid}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  ItemsSource="{Binding Applications}"
                  SelectedItem="{Binding SelectedApplication}"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  PreviewMouseRightButtonDown="ApplicationsDataGrid_PreviewMouseRightButtonDown">

            <DataGrid.InputBindings>
                <MouseBinding Gesture="LeftDoubleClick"
                              Command="{Binding OpenDetailsCommand}" />
            </DataGrid.InputBindings>

            <DataGrid.ContextMenu>
                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem Header="Одобрить заявление"
                              Command="{Binding ApproveApplicationCommand}" />
                    <MenuItem Header="Отклонить заявление"
                              Command="{Binding RejectApplicationCommand}" />
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер заявки" Binding="{Binding ApplicationNumber}"/>
                <DataGridTextColumn Header="Договор" Binding="{Binding Contract.ContractNumber}"/>
                <DataGridTextColumn Header="Гражданин" Binding="{Binding Contract.Person.FullName}"/>
                <DataGridTextColumn Header="Квартира" Binding="{Binding Contract.Apartment.Address}"/>
                <DataGridTextColumn Header="Тип заявки" Binding="{Binding DisplayApplicationType}"/>
                <DataGridTextColumn Header="Дата заявки" Binding="{Binding ApplicationDate, StringFormat=dd.MM.yyyy}"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding DisplayApplicationStatus}"/>
                <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}"/>
                <DataGridTextColumn Header="Добавлено" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
