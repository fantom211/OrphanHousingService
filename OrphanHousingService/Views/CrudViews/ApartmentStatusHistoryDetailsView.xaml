<Window x:Class="OrphanHousingService.Views.CrudViews.ApartmentStatusHistoryDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История статуса квартиры"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20">
        <StackPanel>
            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Квартира:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Address}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Статус:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Status}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Основание:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Basis}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}" Margin="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Комментарий:" Style="{StaticResource DetailLabelText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Comment}" Style="{StaticResource DetailValueText}"/>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
