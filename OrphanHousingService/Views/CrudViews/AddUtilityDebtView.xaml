<Window x:Class="OrphanHousingService.Views.CrudViews.AddUtilityDebtView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Добавить долг"
        Width="500"
        Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Договор" Grid.Row="0"/>
        <ComboBox Grid.Row="0"
                  Grid.Column="1"
                  ItemsSource="{Binding Contracts}"
                  SelectedItem="{Binding SelectedContract}"
                  IsEnabled="{Binding IsContractEditable}"
                  IsEditable="True"
                  IsTextSearchEnabled="True"
                  DisplayMemberPath="ContractNumber"/>

        <TextBlock Text="Сумма" Grid.Row="1"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Amount}"/>

        <TextBlock Text="Дата задолженности" Grid.Row="2"/>
        <DatePicker Grid.Row="2" Grid.Column="1" SelectedDate="{Binding DebtDate}"/>

        <TextBlock Text="Начало периода" Grid.Row="3"/>
        <DatePicker Grid.Row="3" Grid.Column="1" SelectedDate="{Binding PeriodStart}"/>

        <TextBlock Text="Конец периода" Grid.Row="4"/>
        <DatePicker Grid.Row="4" Grid.Column="1" SelectedDate="{Binding PeriodEnd}"/>

        <TextBlock Text="Причина" Grid.Row="5"/>
        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Reason}"/>

        <TextBlock Text="Статус" Grid.Row="6"/>
        <ComboBox Grid.Row="6"
                  Grid.Column="1"
                  ItemsSource="{Binding Statuses}"
                  SelectedValue="{Binding Status}"
                  SelectedValuePath="Value"
                  DisplayMemberPath="Display"/>

        <TextBlock Text="Дата оплаты" Grid.Row="7"/>
        <DatePicker Grid.Row="7" Grid.Column="1" SelectedDate="{Binding PaidDate}"/>

        <StackPanel Grid.Row="8"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">

            <Button Content="Сохранить"
                    Width="120"
                    Margin="0,0,10,0"
                    Command="{Binding SaveCommand}" />

            <Button Content="Отмена"
                    Width="120"
                    Command="{Binding CancelCommand}" />

        </StackPanel>

    </Grid>
</Window>
