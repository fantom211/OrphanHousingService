<Window x:Class="OrphanHousingService.Views.CrudViews.AddPersonView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Height="480"
        Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Фамилия:"/>
        <TextBox Grid.Row="0" Grid.Column="1" Margin="5"
                 Text="{Binding SurName, UpdateSourceTrigger=PropertyChanged}"
                 Tag="Иванов"/>

        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Имя:"/>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="5"
                 Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                 Tag="Иван"/>

        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Отчество:"/>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="5"
                 Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                 Tag="Иванович (необязательно)"/>

        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Дата рождения:"/>
        <DatePicker Grid.Row="3" Grid.Column="1" Margin="5" SelectedDate="{Binding BirthDate}"/>

        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Паспортные данные:"/>
        <TextBox Grid.Row="4" Grid.Column="1" Margin="5"
                 Text="{Binding PassportData, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="Формат: XXXX XXXXXX (4 цифры, пробел, 6 цифр)">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Style.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                        <VisualBrush.Visual>
                                            <TextBlock Foreground="Gray" Margin="4,0" Text="2721 856782"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>

        <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Телефон:"/>
        <TextBox Grid.Row="5" Grid.Column="1" Margin="5"
                 Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="+7XXXXXXXXXX"/>

        <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="Статус:"/>
        <TextBox Grid.Row="6" Grid.Column="1" Margin="5"
                 Text="{Binding Status, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="Необязательно"/>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Width="120" Margin="0,0,10,0" Command="{Binding SaveCommand}"/>
            <Button Content="Отмена" Width="120" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>
