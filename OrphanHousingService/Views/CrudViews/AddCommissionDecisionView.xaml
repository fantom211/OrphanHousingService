<Window x:Class="OrphanHousingService.Views.CrudViews.AddCommissionDecisionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AddCommissionDecisionView"
        Height="550"
        Width="800">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Заявка:"
                   VerticalAlignment="Center"/>

        <ComboBox Grid.Row="0"
          Grid.Column="1"
          ItemsSource="{Binding Applications}"
          SelectedItem="{Binding SelectedApplication}"
          IsEditable="True"
          IsTextSearchEnabled="True"
          DisplayMemberPath="ApplicationNumber"/>

        <TextBlock Grid.Row="1"
                   Text="Тип решения:"
                   VerticalAlignment="Center"/>

        <ComboBox Grid.Row="1"
                  Grid.Column="1"
                  ItemsSource="{Binding DecisionTypes}"
                  SelectedValue="{Binding CurrentDecisionType}"
                  SelectedValuePath="Value"
                  DisplayMemberPath="Display"/>

        <TextBlock Grid.Row="2"
                   Text="Номер решения:"
                   VerticalAlignment="Center"/>

        <TextBox Grid.Row="2"
                  Grid.Column="1"
                  Text="{Binding DecisionNumber}"/>

        <TextBlock Grid.Row="3"
                   Text="Дата решения:"
                   VerticalAlignment="Center"/>

        <DatePicker Grid.Row="3"
                    Grid.Column="1"
                    Margin="5"
                    SelectedDate="{Binding DecisionDate}" />

        <TextBlock Grid.Row="4"
                   Text="Результат:"
                   VerticalAlignment="Center"/>

        <ComboBox Grid.Row="4"
                  Grid.Column="1"
                  ItemsSource="{Binding Results}"
                  SelectedValue="{Binding CurrentResult}"
                  SelectedValuePath="Value"
                  DisplayMemberPath="Display"/>

        <TextBlock Grid.Row="5"
                   Text="Причина:"
                   VerticalAlignment="Center"/>

        <TextBox Grid.Row="5"
                 Grid.Column="1"
                 Margin="5"
                 Text="{Binding Reason}" />

        <TextBlock Grid.Row="6"
                   Text="Комментарий:"
                   VerticalAlignment="Center"/>

        <TextBox Grid.Row="6"
                 Grid.Column="1"
                 Margin="5"
                 Text="{Binding Comment}" />

        <StackPanel Grid.Row="7"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">

            <Button Content="Сохранить"
                    Width="120"
                    Margin="0,0,10,0"
                    Command="{Binding SaveCommand}" />

            <Button Content="Отмена"
                    Width="120"
                    Command="{Binding CancelCommand}" />

        </StackPanel>

    </Grid>
</Window>