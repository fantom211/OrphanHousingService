<Window x:Class="OrphanHousingService.Views.CrudViews.AddCommissionDecisionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Height="680"
        Width="640"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource DialogWindow}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20" Padding="4">
        <StackPanel>
            <TextBlock Text="{Binding WindowTitle}" Style="{StaticResource DetailWindowTitle}"/>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Заявка:" Style="{StaticResource DetailLabelText}"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Applications}"
                              SelectedItem="{Binding SelectedApplication}"
                              IsEnabled="{Binding IsApplicationEditable}"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              DisplayMemberPath="ApplicationNumber"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Тип решения:" Style="{StaticResource DetailLabelText}"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding DecisionTypes}"
                              SelectedValue="{Binding CurrentDecisionType}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Display"
                              IsEnabled="{Binding IsDecisionTypeEditable}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Номер решения:" Style="{StaticResource DetailLabelText}"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding DecisionNumber, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Оставьте пустым для автогенерации"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Дата решения:" Style="{StaticResource DetailLabelText}"/>
                    <DatePicker Grid.Column="1" SelectedDate="{Binding DecisionDate}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Результат:" Style="{StaticResource DetailLabelText}"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Results}"
                              SelectedValue="{Binding CurrentResult}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Display"
                              IsEnabled="{Binding IsResultEditable}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Причина:" Style="{StaticResource DetailLabelText}"/>
                    <TextBox Grid.Column="1"
                             Style="{StaticResource ModernMultilineTextBox}"
                             Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Комментарий:" Style="{StaticResource DetailLabelText}"/>
                    <TextBox Grid.Column="1"
                             Style="{StaticResource ModernMultilineTextBox}"
                             Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить" Width="120" Margin="0,0,10,0" Command="{Binding SaveCommand}"/>
                <Button Content="Отмена" Width="120" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
