<Window x:Class="OrphanHousingService.Views.CrudViews.AddFamilyMemberView"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="{Binding WindowTitle}"

        Width="640"

        Height="560"

        ResizeMode="NoResize"

        WindowStartupLocation="CenterOwner"
        Style="{StaticResource DialogWindow}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20" Padding="4">

        <StackPanel>

            <TextBlock Text="{Binding WindowTitle}" Style="{StaticResource DetailWindowTitle}"/>



            <TextBlock Margin="0,0,0,10"

                       Text="Создание по договору: выберите договор, гражданин отображается для ориентира."

                       TextWrapping="Wrap" Foreground="#6B7280"

                       Visibility="{Binding ShowCitizenInfo, Converter={StaticResource BooleanToVisibilityConverter}}"/>



            <TextBlock Margin="0,0,0,10"

                       Text="Создание по гражданину: активный договор подставляется автоматически."

                       TextWrapping="Wrap" Foreground="#6B7280"

                       Visibility="{Binding ShowPersonSourceInfo, Converter={StaticResource BooleanToVisibilityConverter}}"/>



            <Border Style="{StaticResource DetailFieldBorder}"

                    Visibility="{Binding ShowCitizenName, Converter={StaticResource BooleanToVisibilityConverter}}">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="140"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Гражданин:" Style="{StaticResource DetailLabelText}"/>

                    <TextBlock Grid.Column="1" Text="{Binding CitizenDisplayName}"

                               Style="{StaticResource DetailValueText}" FontWeight="SemiBold"/>

                </Grid>

            </Border>



            <Border Style="{StaticResource DetailFieldBorder}">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="140"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Договор:" Style="{StaticResource DetailLabelText}"/>

                    <ComboBox Grid.Column="1"

                              ItemsSource="{Binding Contracts}"

                              SelectedItem="{Binding SelectedContract}"

                              IsEnabled="{Binding IsContractEditable}"

                              IsEditable="True"

                              IsTextSearchEnabled="True"

                              DisplayMemberPath="ContractNumber"/>

                </Grid>

            </Border>



            <Border Style="{StaticResource DetailFieldBorder}">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="140"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Член семьи (ФИО):" Style="{StaticResource DetailLabelText}"/>

                    <TextBox Grid.Column="1" Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>

                </Grid>

            </Border>



            <Border Style="{StaticResource DetailFieldBorder}">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="140"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Дата рождения:" Style="{StaticResource DetailLabelText}"/>

                    <DatePicker Grid.Column="1" SelectedDate="{Binding BirthDate}"/>

                </Grid>

            </Border>



            <Border Style="{StaticResource DetailFieldBorder}" Margin="0,0,0,15">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="140"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Родство:" Style="{StaticResource DetailLabelText}"/>

                    <ComboBox Grid.Column="1"

                              ItemsSource="{Binding RelationshipTypes}"

                              SelectedValue="{Binding RelationshipType}"

                              SelectedValuePath="Value"

                              DisplayMemberPath="Display"/>

                </Grid>

            </Border>



            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                <Button Content="Сохранить" Width="120" Margin="0,0,10,0" Command="{Binding SaveCommand}"/>

                <Button Content="Отмена" Width="120" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}"/>

            </StackPanel>

        </StackPanel>

    </ScrollViewer>

</Window>


