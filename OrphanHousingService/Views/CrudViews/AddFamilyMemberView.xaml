<Window x:Class="OrphanHousingService.Views.CrudViews.AddFamilyMemberView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Добавить члена семьи"
        Width="500"
        Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Договор" Grid.Row="0"/>
        <ComboBox Grid.Row="0"
                  Grid.Column="1"
                  ItemsSource="{Binding Contracts}"
                  SelectedItem="{Binding SelectedContract}"
                  IsEnabled="{Binding IsContractEditable}"
                  IsEditable="True"
                  IsTextSearchEnabled="True"
                  DisplayMemberPath="ContractNumber"/>

        <TextBlock Text="ФИО" Grid.Row="1"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FullName}"/>

        <TextBlock Text="Дата рождения" Grid.Row="2"/>
        <DatePicker Grid.Row="2" Grid.Column="1" SelectedDate="{Binding BirthDate}"/>

        <TextBlock Text="Родство" Grid.Row="3"/>
        <ComboBox Grid.Row="3"
                  Grid.Column="1"
                  ItemsSource="{Binding RelationshipTypes}"
                  SelectedValue="{Binding RelationshipType}"
                  SelectedValuePath="Value"
                  DisplayMemberPath="Display"/>

        <StackPanel Grid.Row="4"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">

            <Button Content="Сохранить"
                    Width="120"
                    Margin="0,0,10,0"
                    Command="{Binding SaveCommand}" />

            <Button Content="Отмена"
                    Width="120"
                    Command="{Binding CancelCommand}" />

        </StackPanel>

    </Grid>
</Window>
