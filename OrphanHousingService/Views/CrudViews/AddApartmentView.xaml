<Window x:Class="OrphanHousingService.Views.CrudViews.AddApartmentView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OrphanHousingService.Views.CrudViews"
        mc:Ignorable="d"
        Title="AddApartmentView" Height="450" Width="800">
    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Адрес:"
                   VerticalAlignment="Center"/>

        <TextBox Grid.Row="0"
                 Grid.Column="1"
                 Margin="5"
                 Text="{Binding Address}" />

        <TextBlock Grid.Row="1"
                   Text="Кадастровый номер:"
                   VerticalAlignment="Center"/>

        <TextBox Grid.Row="1"
                 Grid.Column="1"
                 Margin="5"
                 Text="{Binding CadastralNumber}" />

        <TextBlock Grid.Row="2"
                   Text="Площадь:"
                   VerticalAlignment="Center"/>

        <TextBox Grid.Row="2"
                 Grid.Column="1"
                 Margin="5"
                 Text="{Binding Area}" />

        <TextBlock Grid.Row="3"
                   Text="Количество комнат:"
                   VerticalAlignment="Center"/>

        <TextBox Grid.Row="3"
                 Grid.Column="1"
                 Margin="5"
                 Text="{Binding RoomsCount}" />

        <TextBlock Grid.Row="4"
                   Text="Статус:"
                   VerticalAlignment="Center"/>

        <ComboBox 
            Grid.Row="4" 
            Grid.Column="1" 
            ItemsSource="{Binding Statuses}"
            SelectedValue="{Binding CurrentStatus}"
            SelectedValuePath="Value"
            DisplayMemberPath="Display"
          />

        <TextBlock Grid.Row="5"
                   Text="Дата включения в фонд:"
                   VerticalAlignment="Center"/>

        <DatePicker Grid.Row="5"
                    Grid.Column="1"
                    Margin="5"
                    SelectedDate="{Binding IncludedToFundDate}" />

        <TextBlock Grid.Row="6"
                   Text="Номер приказа:"
                   VerticalAlignment="Center"/>

        <TextBox Grid.Row="6"
                 Grid.Column="1"
                 Margin="5"
                 Text="{Binding InclussionOrderNumber}" />

        <TextBlock Grid.Row="7"
                   Text="Дата приказа:"
                   VerticalAlignment="Center"/>

        <DatePicker Grid.Row="7"
                    Grid.Column="1"
                    Margin="5"
                    SelectedDate="{Binding InclussionOrderDate}" />

        <StackPanel Grid.Row="8"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">

            <Button Content="Сохранить"
                    Width="120"
                    Margin="0,0,10,0"
                    Command="{Binding SaveCommand}" />

            <Button Content="Отмена"
                    Width="120"
                    Command="{Binding CancelCommand}" />

        </StackPanel>

    </Grid>
</Window>
