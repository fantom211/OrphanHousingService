<Window x:Class="OrphanHousingService.Views.CrudViews.AddApartmentStatusHistoryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OrphanHousingService.Views.CrudViews"
        xmlns:behaviors="clr-namespace:OrphanHousingService.Behaviors"
        mc:Ignorable="d"
        Title="AddApartmentStatusHistoryView"
        Width="500"
        Height="270"
        MaxHeight="480"
        ResizeMode="NoResize"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner">    
    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
               Text="Квартира:"
               VerticalAlignment="Center"/>

        <ComboBox Grid.Row="0"
              Grid.Column="1"
              Margin="5"
              ItemsSource="{Binding Apartments}"
              SelectedItem="{Binding SelectedApartment}"
              DisplayMemberPath="Address"/>

        <TextBlock Grid.Row="1"
               Text="Дата изменения:"
               VerticalAlignment="Center"/>

        <DatePicker Grid.Row="1"
                Grid.Column="1"
                Margin="5"
                SelectedDate="{Binding ChangeDate}" />

        <TextBlock Grid.Row="2"
               Text="Статус:"
               VerticalAlignment="Center"/>

        <ComboBox Grid.Row="2"
              Grid.Column="1"
              Margin="5"
              ItemsSource="{Binding Statuses}"
              SelectedValue="{Binding Status}"
              SelectedValuePath="Value"
              DisplayMemberPath="Display"/>

        <TextBlock Grid.Row="3"
               Text="Основание:"
               VerticalAlignment="Center"/>

        <TextBox Grid.Row="3"
                Grid.Column="1"
                Margin="5"
                Text="{Binding Basis}"
                TextWrapping="Wrap"
                AcceptsReturn="True"
                MinHeight="25"
                VerticalScrollBarVisibility="Auto"
                behaviors:TextBoxAutoGrowBehavior.MaxHeight="120"/>

        <TextBlock Grid.Row="4"
               Text="Комментарий:"
               VerticalAlignment="Center"/>

        <TextBox Grid.Row="4"
                Grid.Column="1"
                Margin="5"
                Text="{Binding Comment}"
                TextWrapping="Wrap"
                AcceptsReturn="True"
                MinHeight="25"
                VerticalScrollBarVisibility="Auto"
                behaviors:TextBoxAutoGrowBehavior.MaxHeight="120"/>

        <StackPanel Grid.Row="5"
                Grid.ColumnSpan="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,15,0,0">

            <Button Content="Сохранить"
                Width="120"
                Margin="0,0,10,0"
                Command="{Binding SaveCommand}" />

            <Button Content="Отмена"
                Width="120"
                Command="{Binding CancelCommand}" />

        </StackPanel>

    </Grid>
</Window>
