<Window x:Class="OrphanHousingService.Views.CrudViews.AddApartmentStatusHistoryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:OrphanHousingService.Behaviors"
        Title="{Binding WindowTitle}"
        Width="640"
        Height="480"
        MaxHeight="560"
        ResizeMode="NoResize"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20">
        <StackPanel>
            <TextBlock Text="{Binding WindowTitle}" Style="{StaticResource DetailWindowTitle}"/>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Квартира:" Style="{StaticResource DetailLabelText}"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Apartments}"
                              SelectedItem="{Binding SelectedApartment}"
                              DisplayMemberPath="Address"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Дата изменения:" Style="{StaticResource DetailLabelText}"/>
                    <DatePicker Grid.Column="1" SelectedDate="{Binding ChangeDate}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Статус:" Style="{StaticResource DetailLabelText}"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Statuses}"
                              SelectedValue="{Binding Status}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Display"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Основание:" Style="{StaticResource DetailLabelText}"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding Basis, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="50"
                             VerticalScrollBarVisibility="Auto"
                             behaviors:TextBoxAutoGrowBehavior.MaxHeight="120"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Комментарий:" Style="{StaticResource DetailLabelText}"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="50"
                             VerticalScrollBarVisibility="Auto"
                             behaviors:TextBoxAutoGrowBehavior.MaxHeight="120"/>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить" Width="120" Margin="0,0,10,0" Command="{Binding SaveCommand}"/>
                <Button Content="Отмена" Width="120" Command="{Binding CancelCommand}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
