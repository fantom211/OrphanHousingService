<Window x:Class="OrphanHousingService.Views.CrudViews.AddApplicationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Height="600"
        Width="640"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource DialogWindow}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20" Padding="4">
        <StackPanel>
            <TextBlock Text="{Binding WindowTitle}" Style="{StaticResource DetailWindowTitle}"/>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Номер заявки:" Style="{StaticResource DetailLabelText}"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding ApplicationNumber, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Оставьте пустым для автогенерации"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Договор:" Style="{StaticResource DetailLabelText}"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Contracts}"
                              SelectedItem="{Binding SelectedContract}"
                              IsEnabled="{Binding IsContractEditable}"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              DisplayMemberPath="ContractNumber"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Тип заявки:" Style="{StaticResource DetailLabelText}"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding ApplicationTypes}"
                              SelectedValue="{Binding CurrentApplicationType}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Display"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Дата заявки:" Style="{StaticResource DetailLabelText}"/>
                    <DatePicker Grid.Column="1" SelectedDate="{Binding ApplicationDate}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Статус:" Style="{StaticResource DetailLabelText}"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Statuses}"
                              SelectedValue="{Binding CurrentStatus}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="Display"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource DetailFieldBorder}" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Комментарий:" Style="{StaticResource DetailLabelText}"/>
                    <TextBox Grid.Column="1"
                             Style="{StaticResource ModernMultilineTextBox}"
                             Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить" Width="120" Margin="0,0,10,0" Command="{Binding SaveCommand}"/>
                <Button Content="Отмена" Width="120" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
