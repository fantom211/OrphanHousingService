<Window x:Class="OrphanHousingService.Views.CrudViews.AddContractView"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="{Binding WindowTitle}"

        Width="640"

        Height="720"

        ResizeMode="NoResize"

        WindowStartupLocation="CenterOwner"
        Style="{StaticResource DialogWindow}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20" Padding="4">

        <StackPanel>

            <TextBlock Text="{Binding WindowTitle}" Style="{StaticResource DetailWindowTitle}"/>



            <Border Style="{StaticResource DetailFieldBorder}">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="140"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Сторона договора:" Style="{StaticResource DetailLabelText}"/>

                    <ComboBox Grid.Column="1"

                              ItemsSource="{Binding CounterpartyTypes}"

                              SelectedValue="{Binding CounterpartyType}"

                              SelectedValuePath="Value"

                              DisplayMemberPath="Display"

                              IsEnabled="{Binding IsCounterpartyTypeEditable}"/>

                </Grid>

            </Border>



            <Border Style="{StaticResource DetailFieldBorder}"

                    Visibility="{Binding IsPersonSelectorVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="140"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Гражданин:" Style="{StaticResource DetailLabelText}"/>

                    <ComboBox Grid.Column="1"

                              ItemsSource="{Binding People}"

                              SelectedItem="{Binding SelectedPerson}"

                              IsEnabled="{Binding IsPersonEditable}"

                              IsTextSearchEnabled="True"

                              DisplayMemberPath="FullName"/>

                </Grid>

            </Border>



            <Border Style="{StaticResource DetailFieldBorder}"

                    Visibility="{Binding IsSystemCounterpartyVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="140"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Контрагент:" Style="{StaticResource DetailLabelText}"/>

                    <TextBlock Grid.Column="1"

                               Text="{Binding CounterpartyDisplayName}"

                               Style="{StaticResource DetailValueText}"

                               FontWeight="SemiBold"/>

                </Grid>

            </Border>



            <Border Style="{StaticResource DetailFieldBorder}">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="140"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Квартира:" Style="{StaticResource DetailLabelText}"/>

                    <ComboBox Grid.Column="1"

                              ItemsSource="{Binding Apartments}"

                              SelectedItem="{Binding SelectedApartment}"

                              IsEnabled="{Binding IsApartmentEditable}"

                              IsTextSearchEnabled="True"

                              DisplayMemberPath="Address"/>

                </Grid>

            </Border>



            <Border Style="{StaticResource DetailFieldBorder}">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="140"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Тип договора:" Style="{StaticResource DetailLabelText}"/>

                    <ComboBox Grid.Column="1"

                              ItemsSource="{Binding ContractTypes}"

                              SelectedValue="{Binding ContractType}"

                              SelectedValuePath="Value"

                              DisplayMemberPath="Display"/>

                </Grid>

            </Border>



            <Border Style="{StaticResource DetailFieldBorder}">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="140"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Номер договора:" Style="{StaticResource DetailLabelText}"/>

                    <TextBox Grid.Column="1"
                             Text="{Binding ContractNumber, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Оставьте пустым для автогенерации">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Foreground="{StaticResource TextMutedBrush}"
                                                                   Margin="12,0"
                                                                   FontSize="13"
                                                                   Text="{Binding SuggestedContractNumber, StringFormat=Авто: {0}}"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                </Grid>

            </Border>



            <Border Style="{StaticResource DetailFieldBorder}">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="140"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Дата договора:" Style="{StaticResource DetailLabelText}"/>

                    <DatePicker Grid.Column="1" SelectedDate="{Binding ContractDate}"/>

                </Grid>

            </Border>



            <Border Style="{StaticResource DetailFieldBorder}">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="140"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Дата начала:" Style="{StaticResource DetailLabelText}"/>

                    <DatePicker Grid.Column="1" SelectedDate="{Binding StartDate}"/>

                </Grid>

            </Border>



            <Border Style="{StaticResource DetailFieldBorder}">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="140"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Дата окончания:" Style="{StaticResource DetailLabelText}"/>

                    <DatePicker Grid.Column="1" SelectedDate="{Binding EndDate}"/>

                </Grid>

            </Border>



            <Border Style="{StaticResource DetailFieldBorder}" Margin="0,0,0,15">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="140"/>

                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Статус:" Style="{StaticResource DetailLabelText}"/>

                    <ComboBox Grid.Column="1"

                              ItemsSource="{Binding ContractStatuses}"

                              SelectedValue="{Binding Status}"

                              SelectedValuePath="Value"

                              DisplayMemberPath="Display"/>

                </Grid>

            </Border>



            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                <Button Content="Сохранить" Width="120" Margin="0,0,10,0" Command="{Binding SaveCommand}"/>

                <Button Content="Отмена" Width="120" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}"/>

            </StackPanel>

        </StackPanel>

    </ScrollViewer>

</Window>


