<Window x:Class="OrphanHousingService.Views.CrudViews.AddContractView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="520"
        Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Гражданин:"/>
        <ComboBox Grid.Row="0" Grid.Column="1"
                  ItemsSource="{Binding People}"
                  SelectedItem="{Binding SelectedPerson}"
                  IsEnabled="{Binding IsPersonEditable}"
                  IsEditable="True"
                  IsTextSearchEnabled="True"
                  DisplayMemberPath="FullName"/>

        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Квартира:"/>
        <ComboBox Grid.Row="1" Grid.Column="1"
                  ItemsSource="{Binding Apartments}"
                  SelectedItem="{Binding SelectedApartment}"
                  IsEnabled="{Binding IsApartmentEditable}"
                  IsEditable="True"
                  IsTextSearchEnabled="True"
                  DisplayMemberPath="Address"/>

        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Тип договора:"/>
        <ComboBox Grid.Row="2" Grid.Column="1"
                  ItemsSource="{Binding ContractTypes}"
                  SelectedValue="{Binding ContractType}"
                  SelectedValuePath="Value"
                  DisplayMemberPath="Display"/>

        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Номер договора:"/>
        <TextBox Grid.Row="3" Grid.Column="1"
                 Text="{Binding ContractNumber, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="Оставьте пустым для автогенерации">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Style.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                        <VisualBrush.Visual>
                                            <TextBlock Foreground="Gray" Margin="4,0"
                                                       Text="{Binding SuggestedContractNumber, StringFormat=Авто: {0}}"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>

        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Дата договора:"/>
        <DatePicker Grid.Row="4" Grid.Column="1" SelectedDate="{Binding ContractDate}"/>

        <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Дата начала:"/>
        <DatePicker Grid.Row="5" Grid.Column="1" SelectedDate="{Binding StartDate}"/>

        <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="Дата окончания:"/>
        <DatePicker Grid.Row="6" Grid.Column="1" SelectedDate="{Binding EndDate}"/>

        <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Text="Статус:"/>
        <ComboBox Grid.Row="7" Grid.Column="1"
                  ItemsSource="{Binding ContractStatuses}"
                  SelectedValue="{Binding Status}"
                  SelectedValuePath="Value"
                  DisplayMemberPath="Display"/>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Сохранить" Width="120" Margin="0,0,10,0" Command="{Binding SaveCommand}" />
            <Button Content="Отмена" Width="120" Command="{Binding CancelCommand}" />
        </StackPanel>
    </Grid>
</Window>
