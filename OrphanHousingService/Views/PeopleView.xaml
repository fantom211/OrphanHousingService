<UserControl x:Class="OrphanHousingService.Views.PeopleView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:OrphanHousingService.Behaviors"
        xmlns:controls="clr-namespace:OrphanHousingService.Views.Controls"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SearchPanel Grid.Row="0"/>

        <DataGrid Grid.Row="1"
            x:Name="PeopleDataGrid"
            Style="{StaticResource ModernDataGrid}"
            IsReadOnly="True"
            AutoGenerateColumns="False"
            CanUserSortColumns="True"
            ItemsSource="{Binding People}"
            SelectedItem="{Binding SelectedPerson}"
            PreviewMouseRightButtonDown="PeopleDataGrid_PreviewMouseRightButtonDown">

            <i:Interaction.Behaviors>
                <behaviors:DataGridScrollIntoViewBehavior />
            </i:Interaction.Behaviors>

            <DataGrid.InputBindings>
                <MouseBinding Gesture="LeftDoubleClick"
                              Command="{Binding OpenDetailsCommand}" />
            </DataGrid.InputBindings>

            <DataGrid.ContextMenu>
                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem Header="Добавить договор"
                              Command="{Binding AddContractCommand}" />
                    <MenuItem Header="Добавить члена семьи"
                              Command="{Binding AddFamilyMemberCommand}" />
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Гражданин" Binding="{Binding FullName}" />
                <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}" />
                <DataGridTextColumn Header="Паспортные данные" Binding="{Binding PassportData}" />
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" />
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" />
                <DataGridTextColumn Header="Добавлен" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
