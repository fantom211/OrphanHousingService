<UserControl x:Class="OrphanHousingService.Views.FamilyMembersView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:OrphanHousingService.Views.Controls"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SearchPanel Grid.Row="0"/>

        <DataGrid Grid.Row="1"
                  Style="{StaticResource ModernDataGrid}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  ItemsSource="{Binding FamilyMembers}"
                  SelectedItem="{Binding SelectedFamilyMember}"
                  IsReadOnly="True">

            <DataGrid.InputBindings>
                <MouseBinding Gesture="LeftDoubleClick"
                              Command="{Binding OpenDetailsCommand}" />
            </DataGrid.InputBindings>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Договор" Binding="{Binding Contract.ContractNumber}" />
                <DataGridTextColumn Header="Гражданин" Binding="{Binding Contract.Person.FullName}" />
                <DataGridTextColumn Header="Член семьи" Binding="{Binding FullName}" />
                <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}" />
                <DataGridTextColumn Header="Родство" Binding="{Binding DisplayRelationshipType}" />
                <DataGridTextColumn Header="Добавлен" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
