<UserControl x:Class="OrphanHousingService.Views.FamilyMembersView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">
    <Grid>
        <DataGrid Style="{StaticResource ModernDataGrid}"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding FamilyMembers}"
                  SelectedItem="{Binding SelectedFamilyMember}"
                  IsReadOnly="True">

            <DataGrid.InputBindings>
                <MouseBinding Gesture="LeftDoubleClick"
                              Command="{Binding OpenDetailsCommand}" />
            </DataGrid.InputBindings>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Договор"
                                    Binding="{Binding Contract.ContractNumber}" />
                <DataGridTextColumn Header="Гражданин"
                                    Binding="{Binding Contract.Person.FullName}" />
                <DataGridTextColumn Header="ФИО"
                                    Binding="{Binding FullName}" />
                <DataGridTextColumn Header="Дата рождения"
                                    Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}" />
                <DataGridTextColumn Header="Родство"
                                    Binding="{Binding DisplayRelationshipType}" />
            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</UserControl>
