<UserControl x:Class="OrphanHousingService.Views.ApartmentStatusHistoriesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:OrphanHousingService.Views.Controls"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SearchPanel Grid.Row="0"/>

        <DataGrid Grid.Row="1"
            Style="{StaticResource ModernDataGrid}"
            IsReadOnly="True"
            AutoGenerateColumns="False"
            CanUserSortColumns="True"
            ItemsSource="{Binding Histories}"
            SelectedItem="{Binding SelectedHistory}">

            <DataGrid.InputBindings>
                <MouseBinding Gesture="LeftDoubleClick"
                  Command="{Binding OpenDetailsCommand}" />
            </DataGrid.InputBindings>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Квартира" Width="150" Binding="{Binding Apartment.Address}" />
                <DataGridTextColumn Header="Дата изменения" Binding="{Binding ChangeDate, StringFormat=dd.MM.yyyy HH:mm}" />
                <DataGridTextColumn Header="Статус" Binding="{Binding DisplayStatus}" />
                <DataGridTextColumn Header="Основание" MaxWidth="300" Binding="{Binding Basis}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            <Setter Property="ToolTip" Value="{Binding Basis}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Комментарий" MaxWidth="300" Binding="{Binding Comment}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            <Setter Property="ToolTip" Value="{Binding Comment}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Добавлено" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
